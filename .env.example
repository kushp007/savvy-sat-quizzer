# Copy to `.env` in the project root (same folder as package.json).
# Never commit real API keys.

# Required for POST /api/generate-questions (Express server in `server/index.js`)
OPENAI_API_KEY=sk-...

# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional — API server port (default 3001)
PORT=3001

# Optional — frontend: set only if the API is on another origin (production).
# In local dev, leave unset and use `npm run dev:full` so Vite proxies `/api` to the API server.
# VITE_QUIZ_API_URL=https://your-api.example.com

# Future: MongoDB (see server/db/mongoScaffold.js)
# MONGODB_URI=mongodb+srv://...
# MONGODB_DB=sat_quizzer
